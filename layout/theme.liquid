<!DOCTYPE html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="theme-color" content="" />
    <link rel="canonical" href="{{ canonical_url }}" />
    <link rel="preconnect" href="https://cdn.shopify.com" />
    <link rel="preconnect" href="https://fonts.shopifycdn.com" />
    <link rel="dns-prefetch" href="//logx.optimizely.com" />
    <link rel="dns-prefetch" href="//tags.tiqcdn.com" />
    <link rel="dns-prefetch" href="//cdn.shopify.com" />
    <link rel="stylesheet" href="{{ 'base.css' | asset_url }}" />
    {{ 'section-header.css' | asset_url | stylesheet_tag }}
    {% unless settings.type_body_font.system? %}
      <link rel="preload" as="font" href="{{ settings.type_body_font | font_url }}" type="font/woff2" crossorigin />
    {% endunless %}
    {% unless settings.type_heading_font.system? %}
      <link rel="preload" as="font" href="{{ settings.type_heading_font | font_url }}" type="font/woff2" crossorigin />
    {% endunless %}
    {% unless settings.type_accent_font.system? %}
      <link rel="preload" as="font" href="{{ settings.type_accent_font | font_url }}" type="font/woff2" crossorigin />
    {% endunless %}
    <title>
      {% if page_title %}
        {{ page_title }}
        {%- if current_page != 1 %}
          &ndash; {{ 'pagination.page' | t: page: current_page }}
        {%- endif %}
      {% else %}
        {{ shop.name }}
      {% endif %}
    </title>
    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}" />
    {% endif %}
    {% render 'meta-tags' %}
    <script src="{{ 'constants.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'pubsub.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'on-change.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'details-disclosure.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'header.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
    {{ content_for_header }}
  </head>
  <body class="gradient">
    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      {{ 'accessibility.skip_to_text' | t }}
    </a>
    <!-- Custom Nawab Header -->
    <header style="background:#0a0a0b;border-bottom:1px solid rgba(244,241,234,0.08);padding:18px 48px;position:relative;z-index:100;">
      <div style="display:flex;align-items:center;justify-content:space-between;max-width:100%;">
        <div style="display:flex;align-items:center;gap:24px;flex:1;">
          <a href="/collections/all" style="color:#f4f1ea;text-decoration:none;font-size:11px;letter-spacing:0.2em;text-transform:uppercase;opacity:0.8;transition:opacity 0.2s;">The Drop</a>
          <span style="color:#f4f1ea;opacity:0.4;">·</span>
          <a href="/pages/the-company" style="color:#f4f1ea;text-decoration:none;font-size:11px;letter-spacing:0.2em;text-transform:uppercase;opacity:0.8;transition:opacity 0.2s;">The Company</a>
        </div>
        <div style="flex:0 0 auto;">
          <a href="/" style="color:#f4f1ea;text-decoration:none;font-family:Georgia,serif;font-size:16px;letter-spacing:0.16em;text-transform:uppercase;font-weight:600;">Nawab & Co.</a>
        </div>
        <div style="display:flex;align-items:center;justify-content:flex-end;gap:24px;flex:1;">
          <a href="/pages/about-us" style="color:#f4f1ea;text-decoration:none;font-size:11px;letter-spacing:0.2em;text-transform:uppercase;opacity:0.8;transition:opacity 0.2s;">About</a>
          <span style="color:#f4f1ea;opacity:0.4;">·</span>
          <a href="/cart" style="color:#f4f1ea;text-decoration:none;font-size:11px;letter-spacing:0.2em;text-transform:uppercase;opacity:0.8;transition:opacity 0.2s;">Cart (0)</a>
        </div>
      </div>
    </header>
    <main id="MainContent" class="content-for-index">
      {{ content_for_layout }}
    </main>
    {% section 'footer' %}
  </body>
</html>
