{%- assign claimed = section.settings.claimed -%}
{%- assign total = section.settings.total -%}
{%- assign pct = 0 -%}
{%- if total > 0 -%}
  {%- assign pct = claimed | times: 100 | divided_by: total -%}
{%- endif -%}
{%- if pct > 100 -%}{%- assign pct = 100 -%}{%- endif -%}

<style>
  #fm-{{ section.id }}{background:{{ section.settings.bg_color }};color:{{ section.settings.text_color }};padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;}
  #fm-{{ section.id }} .fm-wrap{max-width:720px;margin:0 auto;padding:0 24px;text-align:center;}
  #fm-{{ section.id }} .fm-eyebrow{font-size:12px;letter-spacing:.28em;text-transform:uppercase;opacity:.55;margin:0 0 18px;}
  #fm-{{ section.id }} .fm-heading{font-family:var(--font-heading--family,Georgia,serif);font-weight:500;font-size:clamp(2rem,4vw,2.6rem);letter-spacing:.03em;margin:0 0 28px;}
  #fm-{{ section.id }} .fm-counter{font-family:var(--font-heading--family,Georgia,serif);font-size:clamp(2.4rem,6vw,3.4rem);line-height:1;margin:0 0 18px;}
  #fm-{{ section.id }} .fm-counter .fm-total{opacity:.4;}
  #fm-{{ section.id }} .fm-track{position:relative;height:3px;width:min(420px,80%);margin:0 auto 14px;background:rgba(244,241,234,.16);overflow:hidden;}
  #fm-{{ section.id }} .fm-fill{position:absolute;top:0;left:0;height:100%;background:{{ section.settings.accent_color }};width:{{ pct }}%;animation:fmGrow-{{ section.id }} 1.1s cubic-bezier(.22,1,.36,1) both;}
  @keyframes fmGrow-{{ section.id }}{from{width:0;}to{width:{{ pct }}%;}}
  #fm-{{ section.id }} .fm-caption{font-size:12px;letter-spacing:.22em;text-transform:uppercase;opacity:.6;margin:0 0 40px;}
  #fm-{{ section.id }} .fm-intro{font-size:1rem;opacity:.78;margin:0 0 22px;}
  #fm-{{ section.id }} .fm-perks{list-style:none;padding:0;margin:0 auto 40px;max-width:560px;display:grid;grid-template-columns:1fr 1fr;gap:14px 32px;}
  #fm-{{ section.id }} .fm-perks li{display:flex;align-items:flex-start;gap:10px;text-align:left;font-size:.95rem;opacity:.85;}
  #fm-{{ section.id }} .fm-perks li::before{content:"";flex:none;width:14px;height:1px;background:{{ section.settings.accent_color }};margin-top:11px;opacity:.7;}
  #fm-{{ section.id }} .fm-btn{display:inline-block;background:{{ section.settings.accent_color }};color:{{ section.settings.bg_color }};text-decoration:none;padding:15px 32px;font-size:12px;letter-spacing:.18em;text-transform:uppercase;font-weight:600;}
  #fm-{{ section.id }} .fm-btn:hover{opacity:.88;}
  @media (max-width:600px){#fm-{{ section.id }} .fm-perks{grid-template-columns:1fr;max-width:320px;}}
</style>

<div id="fm-{{ section.id }}">
  <div class="fm-wrap">
    {%- if section.settings.eyebrow != blank -%}<p class="fm-eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2 class="fm-heading">{{ section.settings.heading }}</h2>{%- endif -%}
    <div class="fm-counter"><span class="fm-claimed">{{ claimed }}</span> <span class="fm-total">/ {{ total }}</span></div>
    <div class="fm-track"><div class="fm-fill"></div></div>
    {%- if section.settings.caption != blank -%}<p class="fm-caption">{{ section.settings.caption }}</p>{%- endif -%}
    {%- if section.settings.intro != blank -%}<p class="fm-intro">{{ section.settings.intro }}</p>{%- endif -%}
    {%- if section.blocks.size > 0 -%}
    <ul class="fm-perks">
      {%- for block in section.blocks -%}
        {%- if block.type == 'perk' -%}<li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>{%- endif -%}
      {%- endfor -%}
    </ul>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}<a class="fm-btn" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>{%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Founding Members",
  "tag": "section",
  "settings": [
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"The Company"},
    {"type":"text","id":"heading","label":"Heading","default":"Founding Members"},
    {"type":"number","id":"claimed","label":"Spots claimed","default":37},
    {"type":"number","id":"total","label":"Total spots","default":100},
    {"type":"text","id":"caption","label":"Caption under bar","default":"spots claimed"},
    {"type":"text","id":"intro","label":"Intro line","default":"The first 100 members of The Company receive:"},
    {"type":"header","content":"Call to action"},
    {"type":"text","id":"button_label","label":"Button label","default":"Applications Open →"},
    {"type":"url","id":"button_link","label":"Button link"},
    {"type":"header","content":"Style"},
    {"type":"color","id":"bg_color","label":"Background","default":"#0a0a0b"},
    {"type":"color","id":"text_color","label":"Text","default":"#f4f1ea"},
    {"type":"color","id":"accent_color","label":"Accent (bar & button)","default":"#f4f1ea"},
    {"type":"range","id":"padding_top","label":"Padding top","min":0,"max":160,"step":4,"unit":"px","default":80},
    {"type":"range","id":"padding_bottom","label":"Padding bottom","min":0,"max":160,"step":4,"unit":"px","default":80}
  ],
  "blocks": [
    {"type":"perk","name":"Perk","settings":[{"type":"text","id":"text","label":"Text","default":"Priority access to future drops"}]}
  ],
  "max_blocks": 8,
  "presets": [
    {"name":"Founding Members","blocks":[{"type":"perk","settings":{"text":"Priority access to future drops"}},{"type":"perk","settings":{"text":"Early access before public release"}},{"type":"perk","settings":{"text":"Founding member recognition"}},{"type":"perk","settings":{"text":"Access to member-only releases"}}]}
  ]
}
{% endschema %}
