<link rel="stylesheet" href="{{ 'nc-homepage.css' | asset_url }}" media="all">

<footer class="nc-footer" role="contentinfo">

  <div class="nc-footer__top">

    <div class="nc-footer__brand">
      {%- if settings.logo != blank -%}
        <a href="/" class="nc-footer__logo-link" aria-label="{{ shop.name }}">
          {{- settings.logo | image_url: width: 360 | image_tag: loading: 'lazy', class: 'nc-footer__logo', alt: shop.name, widths: '180,240,360' -}}
        </a>
      {%- else -%}
        <a href="/" class="nc-footer__wordmark" aria-label="{{ shop.name }}">{{ shop.name | upcase }}</a>
      {%- endif -%}
      {%- if section.settings.tagline != blank -%}
        <p class="nc-footer__tagline">{{ section.settings.tagline }}</p>
      {%- endif -%}
    </div>

    {%- if section.settings.show_newsletter -%}
      <div class="nc-footer__newsletter">
        <p class="nc-footer__newsletter-label">{{ section.settings.newsletter_heading | default: 'Stay in the loop' | upcase }}</p>
        {%- form 'customer' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          {%- if form.posted_successfully? -%}
            <p class="nc-footer__newsletter-success">{{ section.settings.newsletter_success | default: 'Thanks for subscribing.' }}</p>
          {%- else -%}
            <div class="nc-footer__newsletter-row">
              <input
                type="email"
                name="contact[email]"
                placeholder="{{ section.settings.newsletter_placeholder | default: 'your@email.com' }}"
                class="nc-footer__email-input"
                required
                autocomplete="email"
                aria-label="Email address"
              >
              <button type="submit" class="nc-footer__email-btn" aria-label="Subscribe">&#8594;</button>
            </div>
            {%- if form.errors -%}
              <p class="nc-footer__newsletter-error">{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</p>
            {%- endif -%}
          {%- endif -%}
        {%- endform -%}
      </div>
    {%- endif -%}

  </div>

  {%- if section.blocks.size > 0 -%}
    <nav class="nc-footer__nav" aria-label="Footer navigation">
      {%- for block in section.blocks -%}
        {%- if block.type == 'nav_column' -%}
          <div class="nc-footer__nav-col" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <p class="nc-footer__nav-title">{{ block.settings.title | upcase }}</p>
            {%- endif -%}
            <ul class="nc-footer__nav-list" role="list">
              {%- assign lbl1 = block.settings.link_label_1 -%}
              {%- assign url1 = block.settings.link_url_1 -%}
              {%- if lbl1 != blank and url1 != blank -%}<li><a href="{{ url1 }}" class="nc-footer__nav-link">{{ lbl1 }}</a></li>{%- endif -%}
              {%- assign lbl2 = block.settings.link_label_2 -%}
              {%- assign url2 = block.settings.link_url_2 -%}
              {%- if lbl2 != blank and url2 != blank -%}<li><a href="{{ url2 }}" class="nc-footer__nav-link">{{ lbl2 }}</a></li>{%- endif -%}
              {%- assign lbl3 = block.settings.link_label_3 -%}
              {%- assign url3 = block.settings.link_url_3 -%}
              {%- if lbl3 != blank and url3 != blank -%}<li><a href="{{ url3 }}" class="nc-footer__nav-link">{{ lbl3 }}</a></li>{%- endif -%}
              {%- assign lbl4 = block.settings.link_label_4 -%}
              {%- assign url4 = block.settings.link_url_4 -%}
              {%- if lbl4 != blank and url4 != blank -%}<li><a href="{{ url4 }}" class="nc-footer__nav-link">{{ lbl4 }}</a></li>{%- endif -%}
              {%- assign lbl5 = block.settings.link_label_5 -%}
              {%- assign url5 = block.settings.link_url_5 -%}
              {%- if lbl5 != blank and url5 != blank -%}<li><a href="{{ url5 }}" class="nc-footer__nav-link">{{ lbl5 }}</a></li>{%- endif -%}
              {%- assign lbl6 = block.settings.link_label_6 -%}
              {%- assign url6 = block.settings.link_url_6 -%}
              {%- if lbl6 != blank and url6 != blank -%}<li><a href="{{ url6 }}" class="nc-footer__nav-link">{{ lbl6 }}</a></li>{%- endif -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </nav>
  {%- endif -%}

  {%- assign nc_ig = section.settings.instagram_url -%}
  {%- assign nc_tw = section.settings.twitter_url -%}
  {%- assign nc_fb = section.settings.facebook_url -%}
  {%- assign nc_yt = section.settings.youtube_url -%}
  {%- assign nc_tt = section.settings.tiktok_url -%}
  {%- if nc_ig != blank or nc_tw != blank or nc_fb != blank or nc_yt != blank or nc_tt != blank -%}
    <div class="nc-footer__social">
      {%- if nc_ig != blank -%}
        <a href="{{ nc_ig }}" class="nc-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
        </a>
      {%- endif -%}
      {%- if nc_tw != blank -%}
        <a href="{{ nc_tw }}" class="nc-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      {%- endif -%}
      {%- if nc_fb != blank -%}
        <a href="{{ nc_fb }}" class="nc-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
      {%- endif -%}
      {%- if nc_yt != blank -%}
        <a href="{{ nc_yt }}" class="nc-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      {%- endif -%}
      {%- if nc_tt != blank -%}
        <a href="{{ nc_tt }}" class="nc-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34l-.01-8.37a8.19 8.19 0 0 0 4.79 1.52V5.01a4.85 4.85 0 0 1-1.01-.32z"/></svg>
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="nc-footer__bottom">
    <p class="nc-footer__copyright">
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}{% if section.settings.copyright_extra != blank %} &middot; {{ section.settings.copyright_extra }}{% endif %}
    </p>
    {%- if shop.policies.size > 0 -%}
      <ul class="nc-footer__policies" role="list">
        {%- for policy in shop.policies -%}
          <li><a href="{{ policy.url }}" class="nc-footer__policy-link">{{ policy.title }}</a></li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>

</footer>

{% stylesheet %}
  .nc-footer {
    background: #0a0a0a;
    color: rgba(255, 255, 255, 0.7);
    border-block-start: 1px solid rgba(255, 255, 255, 0.08);
    padding-block-start: 4rem;
    padding-block-end: 2rem;
    padding-inline: max(1.5rem, env(safe-area-inset-left));
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .nc-footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media screen and (min-width: 750px) {
    .nc-footer__top {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  .nc-footer__brand {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .nc-footer__logo-link {
    display: inline-block;
    line-height: 0;
  }

  .nc-footer__logo {
    height: clamp(28px, 4vw, 44px);
    width: auto;
    filter: brightness(0) invert(1);
    object-fit: contain;
  }

  .nc-footer__wordmark {
    font-size: clamp(1rem, 2.5vw, 1.5rem);
    font-weight: 900;
    letter-spacing: 0.3em;
    color: #ffffff;
    text-decoration: none;
    text-indent: 0.3em;
  }

  .nc-footer__tagline {
    margin: 0;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.35);
    text-transform: uppercase;
  }

  .nc-footer__newsletter {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .nc-footer__newsletter-label {
    margin: 0;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    color: rgba(255, 255, 255, 0.5);
    text-indent: 0.22em;
  }

  .nc-footer__newsletter-row {
    display: flex;
    max-width: 340px;
  }

  .nc-footer__email-input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-inline-end: none;
    color: #ffffff;
    padding: 0.7rem 1rem;
    font-size: 0.8rem;
    outline: none;
    transition: border-color 0.2s ease;
    -webkit-appearance: none;
  }

  .nc-footer__email-input::placeholder {
    color: rgba(255, 255, 255, 0.25);
  }

  .nc-footer__email-input:focus {
    border-color: rgba(255, 255, 255, 0.5);
  }

  .nc-footer__email-btn {
    flex-shrink: 0;
    background: #ffffff;
    color: #0a0a0a;
    border: 1px solid #ffffff;
    padding: 0.7rem 1.125rem;
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
    -webkit-appearance: none;
  }

  .nc-footer__email-btn:hover,
  .nc-footer__email-btn:focus-visible {
    background: rgba(255, 255, 255, 0.85);
    outline: none;
  }

  .nc-footer__newsletter-success {
    margin: 0;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.6);
    text-transform: uppercase;
  }

  .nc-footer__newsletter-error {
    margin: 0.5rem 0 0;
    font-size: 0.72rem;
    color: #ff6b6b;
  }

  .nc-footer__nav {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem 1.5rem;
  }

  @media screen and (min-width: 750px) {
    .nc-footer__nav {
      grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    }
  }

  .nc-footer__nav-title {
    margin: 0 0 1rem;
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    color: rgba(255, 255, 255, 0.4);
    text-indent: 0.22em;
  }

  .nc-footer__nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .nc-footer__nav-link {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 0.2s ease;
  }

  .nc-footer__nav-link:hover,
  .nc-footer__nav-link:focus-visible {
    color: #ffffff;
    outline: none;
  }

  .nc-footer__social {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .nc-footer__social-link {
    display: inline-flex;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nc-footer__social-link:hover,
  .nc-footer__social-link:focus-visible {
    color: #ffffff;
    outline: none;
  }

  .nc-footer__bottom {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-block-start: 2rem;
    border-block-start: 1px solid rgba(255, 255, 255, 0.06);
  }

  @media screen and (min-width: 750px) {
    .nc-footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .nc-footer__copyright {
    margin: 0;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.25);
    text-transform: uppercase;
  }

  .nc-footer__policies {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
  }

  .nc-footer__policy-link {
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.25);
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }

  .nc-footer__policy-link:hover,
  .nc-footer__policy-link:focus-visible {
    color: rgba(255, 255, 255, 0.6);
    outline: none;
  }
{% endstylesheet %}

