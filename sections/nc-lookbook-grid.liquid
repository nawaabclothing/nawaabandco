<link rel="stylesheet" href="{{ 'nc-homepage.css' | asset_url }}" media="all">
<script src="{{ 'nc-animations.js' | asset_url }}" type="module" fetchpriority="low"></script>

<section
  class="nc-lookbook"
  style="
    padding-block-start: {{ section.settings.padding_top }}px;
    padding-block-end: {{ section.settings.padding_bottom }}px;
  "
>
  {%- if section.settings.title != blank -%}
    <div class="nc-lookbook__heading nc-fade-in">
      <h2 class="nc-lookbook__title">{{ section.settings.title | upcase }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="nc-lookbook__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="nc-lookbook__grid">
    {%- for block in section.blocks -%}
      {%- liquid
        assign is_video = false
        if block.settings.media_type == 'video' and block.settings.video_url != blank
          assign is_video = true
        endif
        assign has_media = is_video
        unless has_media
          if block.settings.image != blank
            assign has_media = true
          endif
        endunless
        assign has_ig_link = false
        if block.settings.instagram_url != blank
          assign has_ig_link = true
        endif
      -%}
      {%- if has_media -%}
        <div
          class="nc-lookbook__item nc-fade-in"
          data-delay="{{ forloop.index | modulo: 4 | plus: 1 }}"
          {{ block.shopify_attributes }}
        >
          <div class="nc-lookbook__link">
            {%- if is_video -%}
              <video
                class="nc-lookbook__video"
                autoplay
                muted
                loop
                playsinline
                tabindex="0"
                aria-label="Lookbook video. Press Enter or Space to toggle sound."
                data-nc-video
              >
                <source src="{{ block.settings.video_url }}" type="video/mp4">
              </video>
              <span class="nc-lookbook__mute-indicator" aria-hidden="true">
                <svg class="nc-icon-muted" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
                  <line x1="23" y1="9" x2="17" y2="15"/>
                  <line x1="17" y1="9" x2="23" y2="15"/>
                </svg>
                <svg class="nc-icon-unmuted" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
                  <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
                  <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
                </svg>
              </span>
            {%- else -%}
              {{-
                block.settings.image
                | image_url: width: 1200
                | image_tag:
                  loading: 'lazy',
                  class: 'nc-lookbook__img nc-parallax-img',
                  sizes: '(min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw',
                  widths: '400,600,800,1000,1200',
                  alt: block.settings.image.alt | default: section.settings.title
              -}}
            {%- endif -%}
            {%- if has_ig_link -%}
              <a
                href="{{ block.settings.instagram_url }}"
                class="nc-lookbook__ig-btn"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="View on Instagram"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

<script type="module">
  const section = document.getElementById('shopify-section-{{ section.id }}');
  for (const video of section.querySelectorAll('[data-nc-video]')) {
    const item = video.closest('.nc-lookbook__item');
    const toggle = () => {
      video.muted = !video.muted;
      item.classList.toggle('nc-lookbook__item--unmuted', !video.muted);
    };
    video.addEventListener('click', toggle);
    video.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        toggle();
      }
    });
  }
</script>

{% stylesheet %}
  .nc-lookbook {
    background: #0a0a0a;
    color: #ffffff;
  }

  .nc-lookbook__heading {
    text-align: center;
    padding-inline: 1.5rem;
    margin-block-end: 2.5rem;
  }

  .nc-lookbook__title {
    margin: 0 0 0.5rem;
    font-size: clamp(1.25rem, 3vw, 2.25rem);
    font-weight: 900;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-indent: 0.22em;
    color: #ffffff;
    line-height: 1;
  }

  .nc-lookbook__subtitle {
    margin: 0;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.45);
    text-transform: uppercase;
  }

  /* CSS-native masonry via columns */
  .nc-lookbook__grid {
    columns: 2;
    column-gap: 3px;
    padding-inline: 3px;
  }

  @media screen and (min-width: 750px) {
    .nc-lookbook__grid {
      columns: 3;
    }
  }

  @media screen and (min-width: 990px) {
    .nc-lookbook__grid {
      columns: 4;
    }
  }

  .nc-lookbook__item {
    break-inside: avoid;
    margin-block-end: 3px;
    overflow: hidden;
  }

  .nc-lookbook__link {
    display: block;
    overflow: hidden;
    position: relative;
  }

  /* Images */
  .nc-lookbook__img {
    display: block;
    width: 100%;
    height: auto;
    /* scale slightly larger so parallax shift stays within bounds */
    transform: translateY(0) scale(1.12);
    transform-origin: center center;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  .nc-lookbook__link:hover .nc-lookbook__img {
    transform: scale(1.17);
  }

  /* Videos */
  .nc-lookbook__video {
    display: block;
    width: 100%;
    height: auto;
    cursor: pointer;
    transform: scale(1.12);
    transform-origin: center center;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  .nc-lookbook__link:hover .nc-lookbook__video {
    transform: scale(1.17);
  }

  .nc-lookbook__video:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: -2px;
  }

  /* Mute/unmute indicator */
  .nc-lookbook__mute-indicator {
    position: absolute;
    bottom: 0.5rem;
    inset-inline-start: 0.5rem;
    z-index: 2;
    color: #ffffff;
    background: rgba(0, 0, 0, 0.55);
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    backdrop-filter: blur(4px);
  }

  .nc-lookbook__mute-indicator .nc-icon-unmuted {
    display: none;
  }

  .nc-lookbook__item--unmuted .nc-lookbook__mute-indicator .nc-icon-muted {
    display: none;
  }

  .nc-lookbook__item--unmuted .nc-lookbook__mute-indicator .nc-icon-unmuted {
    display: block;
  }

  /* Instagram icon overlay */
  .nc-lookbook__ig-btn {
    position: absolute;
    bottom: 0.5rem;
    inset-inline-end: 0.5rem;
    z-index: 2;
    color: #ffffff;
    background: rgba(0, 0, 0, 0.55);
    width: 30px;
    height: 30px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    backdrop-filter: blur(4px);
    transition: background 0.25s ease;
  }

  .nc-lookbook__ig-btn:hover {
    background: rgba(0, 0, 0, 0.8);
  }

  .nc-lookbook__ig-btn:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .nc-lookbook__img,
    .nc-lookbook__video {
      transform: none !important;
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Lookbook Grid",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 12,
  "blocks": [
    {
      "type": "media",
      "name": "Media Item",
      "settings": [
        {
          "type": "select",
          "id": "media_type",
          "label": "Media type",
          "options": [
            {
              "value": "image",
              "label": "Image"
            },
            {
              "value": "video",
              "label": "Video"
            }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL (MP4)"
        },
        {
          "type": "url",
          "id": "instagram_url",
          "label": "Instagram URL (optional)"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Lookbook"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:settings.top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Lookbook Grid",
      "category": "t:categories.storytelling",
      "blocks": [
        {"type": "media"},
        {"type": "media"},
        {"type": "media"},
        {"type": "media"}
      ]
    }
  ]
}
{% endschema %}
