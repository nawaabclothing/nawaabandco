{%- assign img = section.settings.hero_image -%}
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,400;1,500&display=swap" rel="stylesheet">
<style>
  #he-{{ section.id }}{position:relative;min-height:{{ section.settings.height }}vh;display:flex;align-items:flex-end;overflow:hidden;background:#0a0a0b;}
  #he-{{ section.id }} .he-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 28%;filter:grayscale(.12) contrast(1.02);}
  #he-{{ section.id }} .he-scrim{position:absolute;inset:0;background:linear-gradient(180deg,rgba(10,10,11,.55) 0%,rgba(10,10,11,.12) 38%,rgba(10,10,11,.82) 100%);}
  #he-{{ section.id }} .he-scrim2{position:absolute;inset:0;background:linear-gradient(90deg,rgba(10,10,11,.72) 0%,rgba(10,10,11,0) 55%);}
  #he-{{ section.id }} .he-wrap{position:relative;z-index:2;padding:0 clamp(24px,5vw,64px) clamp(48px,7vh,72px);max-width:900px;color:{{ section.settings.text_color }};}
  #he-{{ section.id }} .he-eyebrow{display:flex;align-items:center;gap:14px;margin-bottom:26px;font-size:11px;letter-spacing:.28em;text-transform:uppercase;opacity:.72;}
  #he-{{ section.id }} .he-eyebrow .ln{width:28px;height:1px;background:currentColor;opacity:.5;}
  #he-{{ section.id }} .he-title{font-family:'Cormorant Garamond',Georgia,serif;font-weight:500;font-size:clamp(46px,8vw,108px);line-height:.92;letter-spacing:-.01em;margin:0 0 24px;}
  #he-{{ section.id }} .he-title em{font-style:italic;font-weight:400;}
  #he-{{ section.id }} .he-body{font-size:clamp(15px,1.4vw,16px);line-height:1.6;max-width:520px;opacity:.82;margin:0 0 40px;}
  #he-{{ section.id }} .he-cta{display:flex;flex-wrap:wrap;align-items:center;gap:22px;}
  #he-{{ section.id }} .he-btn{display:inline-flex;align-items:center;gap:12px;background:{{ section.settings.accent_color }};color:#0a0a0b;text-decoration:none;padding:16px 30px;font-size:12px;letter-spacing:.18em;text-transform:uppercase;font-weight:600;}
  #he-{{ section.id }} .he-btn:hover{opacity:.9;}
  #he-{{ section.id }} .he-link{display:inline-flex;align-items:center;color:{{ section.settings.text_color }};text-decoration:none;padding:14px 2px;font-size:12px;letter-spacing:.18em;text-transform:uppercase;border-bottom:1px solid rgba(244,241,234,.5);}
  #he-{{ section.id }} .he-link:hover{border-color:{{ section.settings.accent_color }};}
</style>
<section id="he-{{ section.id }}">
  {%- if img -%}<img class="he-img" src="{{ img | image_url: width: 2400 }}" alt="" loading="eager" width="2400" height="1350">{%- endif -%}
  <div class="he-scrim"></div>
  <div class="he-scrim2"></div>
  <div class="he-wrap">
    <div class="he-eyebrow">{%- if section.settings.eyebrow_a != blank -%}<span>{{ section.settings.eyebrow_a }}</span>{%- endif -%}<span class="ln"></span>{%- if section.settings.eyebrow_b != blank -%}<span>{{ section.settings.eyebrow_b }}</span>{%- endif -%}</div>
    <h1 class="he-title">{{ section.settings.title_line1 }}<br><em>{{ section.settings.title_line2 }}</em></h1>
    {%- if section.settings.body != blank -%}<p class="he-body">{{ section.settings.body }}</p>{%- endif -%}
    <div class="he-cta">
      {%- if section.settings.cta1_label != blank -%}<a class="he-btn" href="{{ section.settings.cta1_link }}">{{ section.settings.cta1_label }} <span>&rarr;</span></a>{%- endif -%}
      {%- if section.settings.cta2_label != blank -%}<a class="he-link" href="{{ section.settings.cta2_link }}">{{ section.settings.cta2_label }}</a>{%- endif -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Editorial Hero",
  "tag": "section",
  "settings": [
    {"type":"image_picker","id":"hero_image","label":"Background image"},
    {"type":"range","id":"height","label":"Height (vh)","min":60,"max":100,"step":2,"unit":"vh","default":88},
    {"type":"text","id":"eyebrow_a","label":"Eyebrow left","default":"Drop 001"},
    {"type":"text","id":"eyebrow_b","label":"Eyebrow right","default":"Modern Nobility"},
    {"type":"text","id":"title_line1","label":"Headline line 1","default":"For everyone who"},
    {"type":"text","id":"title_line2","label":"Headline line 2 (italic)","default":"stopped shrinking."},
    {"type":"textarea","id":"body","label":"Body","default":"You grew up code-switching — translating yourself for rooms that weren't built for you. Nawab means nobility. It was never lost, just waiting."},
    {"type":"text","id":"cta1_label","label":"Primary button label","default":"Shop Drop 001"},
    {"type":"url","id":"cta1_link","label":"Primary button link"},
    {"type":"text","id":"cta2_label","label":"Secondary link label","default":"Apply to The Company"},
    {"type":"url","id":"cta2_link","label":"Secondary link"},
    {"type":"color","id":"text_color","label":"Text","default":"#f4f1ea"},
    {"type":"color","id":"accent_color","label":"Accent (button)","default":"#f4f1ea"}
  ],
  "presets": [{"name":"Editorial Hero"}]
}
{% endschema %}
